PORT=3001
DATABASE_URL=postgresql://usuario:senha@localhost:5432/nomedobanco
NODE_ENV=development

# JWT Configuration
JWT_SECRET=sua-chave-secreta-forte-aqui
JWT_EXPIRES_IN=24h

# Frontend Settings
FRONTEND_URL=http://localhost:5173

# Mattermost / Chat Integration (Opcional)
MATTERMOST_WEBHOOK_URL=http://chat.sua-empresa.com/hooks/xyz

# Email Configuration (SMTP) (Opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=seu-email@gmail.com

# AuroraVoice / SIP Configurations (Opcional)
AURORA_API_KEY=sua-chave-aurora
AURORA_BASE_URL=https://api.auroravoice.com
VISITOR_EXTENSION=11012

# Google OAuth Configuration (Opcional)
GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
ALLOWED_DOMAIN=suaempresa.com.br
SESSION_SECRET=uma-chave-de-sessao-forte

